class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        if (head == NULL || head->next == NULL) {
            return head;
        }
        
        int length = 1;
        ListNode* temp = head;
        while (temp->next != NULL) {
            temp = temp->next;
            length++;
        }
        
        k = k % length;
        if (k == 0) {
            return head;
        }
        
        ListNode* current = head;
        for (int i = 0; i < length - k - 1; i++) {
            current = current->next;
        }
        
        ListNode* newHead = current->next;
        current->next = NULL;
        temp->next = head;
        
        return newHead;
    }
};
